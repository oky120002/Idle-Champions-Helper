{
  "name": "idle-champions-helper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "test:regression": "npm run lint && npm run typecheck && npm run test:run && npm run test:e2e",
    "playwright:install": "playwright install chromium",
    "preview": "vite preview",
    "preview:pages": "node scripts/serve-github-pages-preview.mjs",
    "data:fetch": "node scripts/fetch-idle-champions-definitions.mjs",
    "data:normalize": "node scripts/normalize-idle-champions-definitions.mjs",
    "data:portraits": "node scripts/sync-idle-champions-portraits.mjs",
    "data:build": "node scripts/build-idle-champions-data.mjs"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
